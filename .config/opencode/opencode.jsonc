{
	"$schema": "https://opencode.ai/config.json",
	"plugin": [
		"@mohak34/opencode-notifier@0.1.26"
	],
	"tui": {
		"scroll_speed": 1,
		"scroll_acceleration": {
			"enabled": false
		}
	},
	"permission": {
		"*": "ask",
		"read": {
			"*": "allow",
			"*.env": "deny",
			"*.env.*": "deny",
			"*.env.example": "allow"
		},
		"grep": {
			"*": "allow",
			"*.env": "deny",
			"*.env.*": "deny",
			"*.env.example": "allow"
		},
		"glob": "allow",
		"todowrite": "allow",
		"todoread": "allow",
		"websearch": "allow",
		"codesearch": "allow",
		"list": "allow",
		"bash": {
			"*": "ask",
			"git log *": "allow",
			"git status *": "allow"
		}
	},
	"agent": {
		"Allow Edits": {
			"mode": "primary",
			"tools": {
				"*": true
			},
			"permission": {
				"edit": "allow"
			}
		}
	}
}
