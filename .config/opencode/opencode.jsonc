{
	"$schema": "https://opencode.ai/config.json",
	"plugin": [
		"@mohak34/opencode-notifier@0.1.26",
		"@plannotator/opencode@latest"
	],
	// Shared config lives here and is safe to track in git.
	// Machine-private overrides live in ~/.config/opencode/opencode.local.jsonc
	// and are loaded via OPENCODE_CONFIG in ~/.bash_profile.
	// Put machine-specific MCP servers and allowlists in the private file.
	"permission": {
		"*": "ask",
		"read": {
			"*": "allow",
			"*.env": "deny",
			"*.env.*": "deny",
			"*.env.example": "allow"
		},
		"grep": {
			"*": "allow",
			"*.env": "deny",
			"*.env.*": "deny",
			"*.env.example": "allow"
		},
		"glob": "allow",
		"todowrite": "allow",
		"todoread": "allow",
		"websearch": "allow",
		"webfetch": "allow",
		"codesearch": "allow",
		"list": "allow",
		"bash": {
			"*": "ask",
			// shell: basic readonly
			"ls": "allow",
			"ls *": "allow",
			"date": "allow",
			"date *": "allow",
			"pwd": "allow",
			"whoami": "allow",
			"uname": "allow",
			"uname *": "allow",
			"which": "allow",
			"which *": "allow",
			"command -v *": "allow",
			"git --version": "allow",
			"node --version": "allow",
			"npm --version": "allow",
			"python3 --version": "allow",
			// mise: read-only task discovery
			"mise tasks": "allow",
			"mise tasks ls": "allow",
			"mise tasks ls *": "allow",
			"mise tasks info *": "allow",
			"mise tasks deps *": "allow",
			"mise tasks validate *": "allow",
			// opencode: safe diagnostics
			"opencode --help": "allow",
			"opencode debug --help": "allow",
			"opencode debug paths": "allow",
			"opencode debug paths *": "allow",
			"opencode debug skill": "allow",
			"opencode debug skill *": "allow",
			"opencode debug scrap": "allow",
			"opencode debug scrap *": "allow",
			// gh: read-only allowlist
			"gh --version": "allow",
			"gh help": "allow",
			"gh help *": "allow",
			"gh auth status": "allow",
			"gh auth status *": "allow",
			"gh status": "allow",
			"gh status *": "allow",
			"gh repo view": "allow",
			"gh repo view *": "allow",
			"gh repo list": "allow",
			"gh repo list *": "allow",
			"gh pr list": "allow",
			"gh pr list *": "allow",
			"gh pr view": "allow",
			"gh pr view *": "allow",
			"gh pr status": "allow",
			"gh pr status *": "allow",
			"gh pr checks": "allow",
			"gh pr checks *": "allow",
			"gh pr diff": "allow",
			"gh pr diff *": "allow",
			"gh issue list": "allow",
			"gh issue list *": "allow",
			"gh issue view": "allow",
			"gh issue view *": "allow",
			"gh issue status": "allow",
			"gh issue status *": "allow",
			"gh run list": "allow",
			"gh run list *": "allow",
			"gh run view": "allow",
			"gh run view *": "allow",
			"gh run watch": "allow",
			"gh run watch *": "allow",
			"gh workflow list": "allow",
			"gh workflow list *": "allow",
			"gh workflow view": "allow",
			"gh workflow view *": "allow",
			"gh release list": "allow",
			"gh release list *": "allow",
			"gh release view": "allow",
			"gh release view *": "allow",
			"gh release verify": "allow",
			"gh release verify *": "allow",
			"gh release verify-asset": "allow",
			"gh release verify-asset *": "allow",
			"gh ruleset list": "allow",
			"gh ruleset list *": "allow",
			"gh ruleset view": "allow",
			"gh ruleset view *": "allow",
			"gh ruleset check": "allow",
			"gh ruleset check *": "allow",
			"gh label list": "allow",
			"gh label list *": "allow",
			"gh org list": "allow",
			"gh org list *": "allow",
			"gh search code": "allow",
			"gh search code *": "allow",
			"gh search commits": "allow",
			"gh search commits *": "allow",
			"gh search issues": "allow",
			"gh search issues *": "allow",
			"gh search prs": "allow",
			"gh search prs *": "allow",
			"gh search repos": "allow",
			"gh search repos *": "allow",
			"gh api *": "allow",
			"gh api -X POST *": "deny",
			"gh api * -X POST *": "deny",
			"gh api --method POST *": "deny",
			"gh api * --method POST *": "deny",
			"gh api -X PUT *": "deny",
			"gh api * -X PUT *": "deny",
			"gh api --method PUT *": "deny",
			"gh api * --method PUT *": "deny",
			"gh api -X PATCH *": "deny",
			"gh api * -X PATCH *": "deny",
			"gh api --method PATCH *": "deny",
			"gh api * --method PATCH *": "deny",
			"gh api -X DELETE *": "deny",
			"gh api * -X DELETE *": "deny",
			"gh api --method DELETE *": "deny",
			"gh api * --method DELETE *": "deny",
			// git: read-only allowlist
			"git status": "allow",
			"git status *": "allow",
			"git log": "allow",
			"git log *": "allow",
			"git diff": "allow",
			"git diff *": "allow",
			"git show": "allow",
			"git show *": "allow",
			"git blame *": "allow",
			"git reflog": "allow",
			"git reflog *": "allow",
			"git rev-parse *": "allow",
			"git symbolic-ref *": "allow",
			"git merge-base *": "allow",
			"git describe *": "allow",
			"git name-rev *": "allow",
			"git rev-list *": "allow",
			"git show-ref": "allow",
			"git show-ref *": "allow",
			"git for-each-ref *": "allow",
			"git ls-files": "allow",
			"git ls-files *": "allow",
			"git ls-tree *": "allow",
			"git cat-file *": "allow",
			"git grep *": "allow",
			"git shortlog": "allow",
			"git shortlog *": "allow",
			"git help *": "allow",
			"git branch --show-current": "allow",
			"git branch --show-current *": "allow",
			"git branch --list": "allow",
			"git branch --list *": "allow",
			"git tag --list": "allow",
			"git tag --list *": "allow",
			"git remote -v": "allow",
			"git remote show *": "allow",
			"git config --get *": "allow",
			"git config --get-all *": "allow",
			"git config --list": "allow",
			"git config --list *": "allow",
			"git stash list": "allow",
			"git stash show": "allow",
			"git stash show *": "allow",
			"git worktree list": "allow",
			"git submodule status": "allow",
			"git submodule status *": "allow"
		}
	},
	"agent": {
		"Allow Edits": {
			"mode": "primary",
			"permission": {
				"edit": "allow"
			}
		}
	}
}
